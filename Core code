<!DOCTYPE html>

<html lang='en'>
<head>
<meta charset='UTF-8'>
<meta name='viewport' content='width=device-width, initial-scale=1.0'>
<title>SummarAI - Learn to Summarize</title>
<link href='https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap' rel='stylesheet'>
<style>
:root{--bg:#0d0d0f;--sur:#16161a;--s2:#1e1e24;--bor:#2a2a35;--acc:#c8f060;--ac2:#60b8f0;--ac3:#f060b8;--txt:#f0f0f5;--mut:#888899;--dan:#f06060;--ok:#60f0a8}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--txt);font-family:'DM Sans',sans-serif;font-size:15px;line-height:1.65;min-height:100vh}
.app{max-width:860px;margin:0 auto;padding:40px 24px 80px}
header{display:flex;align-items:center;justify-content:space-between;margin-bottom:48px}
.logo{font-family:'Syne',sans-serif;font-weight:800;font-size:22px;letter-spacing:-.5px}
.logo span{color:var(--acc)}
.bdg{font-size:11px;font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:var(--mut);border:1px solid var(--bor);padding:4px 12px;border-radius:100px}
.steps{display:flex;align-items:center;margin-bottom:40px}
.step{display:flex;align-items:center;gap:10px;font-size:13px;color:var(--mut);transition:color .3s}
.step.active{color:var(--txt)}.step.done{color:var(--acc)}
.snum{width:28px;height:28px;border-radius:50%;border:1.5px solid currentColor;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:700;font-size:12px;flex-shrink:0}
.step.active .snum,.step.done .snum{background:var(--acc);border-color:var(--acc);color:#000}
.scon{flex:1;height:1px;background:var(--bor);margin:0 10px;max-width:80px}
.card{background:var(--sur);border:1px solid var(--bor);border-radius:16px;padding:32px;margin-bottom:20px}
.ct{font-family:'Syne',sans-serif;font-weight:700;font-size:18px;margin-bottom:6px}
.cs{color:var(--mut);font-size:13.5px;margin-bottom:24px}
.tabs{display:flex;gap:4px;background:var(--s2);border-radius:10px;padding:4px;margin-bottom:20px;width:fit-content}
.tab{padding:7px 18px;border-radius:7px;font-size:13.5px;font-weight:500;cursor:pointer;border:none;background:transparent;color:var(--mut);transition:all .2s;font-family:'DM Sans',sans-serif}
.tab.active{background:var(--sur);color:var(--txt);box-shadow:0 1px 4px rgba(0,0,0,.4)}
textarea{width:100%;background:var(--s2);border:1px solid var(--bor);border-radius:10px;color:var(--txt);font-family:'DM Sans',sans-serif;font-size:14.5px;line-height:1.7;padding:14px 16px;resize:vertical;outline:none;transition:border-color .2s;min-height:180px}
textarea:focus{border-color:var(--acc)}
.dz{border:2px dashed var(--bor);border-radius:12px;padding:40px 20px;text-align:center;cursor:pointer;transition:all .2s;position:relative}
.dz:hover,.dz.drag{border-color:var(--acc);background:rgba(200,240,96,.04)}
.dz input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.fbox{display:flex;align-items:center;gap:12px;background:var(--s2);border:1px solid var(--bor);border-radius:10px;padding:14px 16px}
.btn{display:inline-flex;align-items:center;gap:8px;padding:11px 24px;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:14.5px;font-weight:500;cursor:pointer;border:none;transition:all .2s}
.bp{background:var(--acc);color:#000}.bp:hover:not(:disabled){background:#d8ff70;transform:translateY(-1px);box-shadow:0 4px 20px rgba(200,240,96,.3)}.bp:disabled{opacity:.4;cursor:not-allowed}
.bs{background:var(--s2);color:var(--txt);border:1px solid var(--bor)}.bs:hover{background:var(--bor)}
.bg{background:transparent;color:var(--mut);border:1px solid var(--bor)}.bg:hover{color:var(--txt)}
.ld{display:flex;align-items:center;gap:12px;color:var(--mut);font-size:14px;padding:16px 0}
.sp{width:20px;height:20px;border:2px solid var(--bor);border-top-color:var(--acc);border-radius:50%;animation:spin .8s linear infinite;flex-shrink:0}
@keyframes spin{to{transform:rotate(360deg)}}
.fbb{background:var(--s2);border-radius:12px;padding:20px;margin-bottom:16px;border-left:3px solid var(--bor)}
.fbb.pos{border-left-color:var(--ok)}.fbb.imp{border-left-color:var(--ac2)}.fbb.mis{border-left-color:var(--ac3)}
.fblb{font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;margin-bottom:8px}
.fbb.pos .fblb{color:var(--ok)}.fbb.imp .fblb{color:var(--ac2)}.fbb.mis .fblb{color:var(--ac3)}
.fbb p{font-size:14px;line-height:1.65}
.rw{display:flex;flex-direction:column;align-items:center;margin:0 auto 24px}
.ring{position:relative;width:110px;height:110px}.ring svg{transform:rotate(-90deg)}
.rt{fill:none;stroke:var(--s2);stroke-width:8}.rf{fill:none;stroke-width:8;stroke-linecap:round;transition:stroke-dashoffset 1s ease}
.rtx{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
.rn{font-family:'Syne',sans-serif;font-weight:800;font-size:28px;line-height:1}.rlb{font-size:11px;color:var(--mut)}
.qq{background:var(--s2);border:1px solid var(--bor);border-radius:12px;padding:22px;margin-bottom:16px}
.qn{font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--acc);margin-bottom:8px}
.qt{font-size:15px;font-weight:500;margin-bottom:16px}
.opts{display:flex;flex-direction:column;gap:8px}
.opt{display:flex;align-items:flex-start;gap:10px;background:var(--sur);border:1px solid var(--bor);border-radius:8px;padding:11px 14px;cursor:pointer;font-size:14px;transition:all .18s;text-align:left;color:var(--txt);font-family:'DM Sans',sans-serif;width:100%}
.opt:hover:not(:disabled){border-color:var(--acc);background:rgba(200,240,96,.05)}.opt:disabled{cursor:default}
.opt.correct{border-color:var(--ok);background:rgba(96,240,168,.1)}.opt.wrong{border-color:var(--dan);background:rgba(240,96,96,.08)}
.ol{width:22px;height:22px;border-radius:50%;background:var(--s2);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0;font-family:'Syne',sans-serif;margin-top:1px}
.qr{font-size:13px;margin-top:10px;padding:10px 14px;border-radius:8px;background:var(--sur);color:var(--mut);line-height:1.5;display:none}
.qr.show{display:block}.qr.cm{color:var(--ok)}.qr.wm{color:var(--dan)}
.saw{margin-top:8px}.saw textarea{min-height:80px;font-size:14px}
.panel{display:none}.panel.active{display:block;animation:fu .35s ease}
@keyframes fu{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.fsc{text-align:center;padding:40px;background:var(--sur);border:1px solid var(--bor);border-radius:16px}
.fgr{font-family:'Syne',sans-serif;font-size:72px;font-weight:800;line-height:1;margin-bottom:8px}
.fgr.A{color:var(--ok)}.fgr.B{color:var(--acc)}.fgr.C{color:var(--ac2)}.fgr.D{color:var(--ac3)}.fgr.F{color:var(--dan)}
.fsub{color:var(--mut);margin-bottom:24px}
.fst{display:flex;justify-content:center;gap:32px;margin-bottom:28px}
.sv{font-family:'Syne',sans-serif;font-weight:700;font-size:26px}.slb{font-size:12px;color:var(--mut)}
.err{background:rgba(240,96,96,.1);border:1px solid rgba(240,96,96,.3);border-radius:8px;padding:12px 16px;color:var(--dan);font-size:13.5px;margin-bottom:16px}
.cc{text-align:right;font-size:12px;color:var(--mut);margin-top:6px}
.tp{background:var(--s2);border-radius:10px;padding:16px;max-height:120px;overflow-y:auto;font-size:13.5px;color:var(--mut);line-height:1.65;border:1px solid var(--bor);margin-bottom:16px}
.tp strong{color:var(--txt);display:block;margin-bottom:6px;font-size:12px;letter-spacing:.05em;text-transform:uppercase}
.row{display:flex;gap:10px;flex-wrap:wrap}
</style>
</head>
<body>
<div class="app">
  <header><div class="logo">Summar<span>AI</span></div><div class="bdg">Study Tool</div></header>
  <div class="steps">
    <div class="step active" id="si1"><div class="snum">1</div><span>Load Text</span></div>
    <div class="scon"></div>
    <div class="step" id="si2"><div class="snum">2</div><span>Summarize</span></div>
    <div class="scon"></div>
    <div class="step" id="si3"><div class="snum">3</div><span>Feedback</span></div>
    <div class="scon"></div>
    <div class="step" id="si4"><div class="snum">4</div><span>Quiz</span></div>
  </div>
  <div class="panel active" id="p1">
    <div class="card">
      <div class="ct">Load your text</div>
      <div class="cs">Upload a .txt file or paste a passage to get started.</div>
      <div class="tabs">
        <button class="tab active" onclick="switchTab('paste')">Paste Text</button>
        <button class="tab" onclick="switchTab('file')">Upload File</button>
      </div>
      <div id="t-p">
        <textarea id="pin" placeholder="Paste an article, chapter, or any passage here..." oninput="ucc()"></textarea>
        <div class="cc"><span id="cc">0</span> characters</div>
      </div>
      <div id="t-f" style="display:none">
        <div id="dz-w">
          <div class="dz" id="dz" ondragover="dov(event)" ondragleave="dol()" ondrop="dodrop(event)">
            <input type="file" accept=".txt,.md" onchange="hfile(event)">
            <div style="font-size:36px;margin-bottom:10px">&#128196;</div>
            <div style="color:var(--mut);font-size:14px"><strong style="color:var(--txt)">Drop a .txt or .md file</strong> or click to browse</div>
          </div>
        </div>
        <div id="fl-d" style="display:none"></div>
      </div>
      <div style="margin-top:20px"><button class="btn bp" id="btn1" onclick="go2()" disabled>Continue to Summarize &#8594;</button></div>
    </div>
  </div>
  <div class="panel" id="p2">
    <div class="card">
      <div class="ct">Read &amp; Summarize</div>
      <div class="cs">Read the passage below, then write your summary in your own words.</div>
      <div class="tp"><strong>Source Text</strong><span id="pv2"></span></div>
      <label style="font-size:13px;color:var(--mut);font-weight:500;display:block;margin-bottom:8px">Your Summary</label>
      <textarea id="usum" placeholder="Write the main ideas, key points, and important details..." style="min-height:200px" oninput="csum()"></textarea>
      <div class="cc"><span id="sc">0</span> characters</div>
      <div id="serr" class="err" style="display:none;margin-top:12px">Please write at least 80 characters before getting feedback.</div>
      <div class="row" style="margin-top:20px">
        <button class="btn bg" onclick="goP(1)">&#8592; Back</button>
        <button class="btn bp" id="bfb" onclick="getFB()" disabled>Get AI Feedback &#8594;</button>
      </div>
    </div>
  </div>
  <div class="panel" id="p3">
    <div class="card">
      <div class="ct">AI Feedback</div>
      <div class="cs">Here is a detailed breakdown of your summary.</div>
      <div id="fbl" class="ld"><div class="sp"></div> Analyzing your summary&#8230;</div>
      <div id="fbc" style="display:none"></div>
      <div id="fba" class="row" style="display:none;margin-top:24px">
        <button class="btn bg" onclick="goP(2)">&#8592; Revise Summary</button>
        <button class="btn bp" onclick="startQuiz()">Take the Quiz &#8594;</button>
      </div>
    </div>
  </div>
  <div class="panel" id="p4">
    <div class="card">
      <div class="ct">Knowledge Quiz</div>
      <div class="cs">Answer questions about the text to test your comprehension.</div>
      <div id="ql" class="ld"><div class="sp"></div> Generating quiz&#8230;</div>
      <div id="qc" style="display:none"></div>
      <div id="qa" class="row" style="display:none;margin-top:20px">
        <button class="btn bp" id="bsub" onclick="submitQuiz()">Submit Quiz &#8594;</button>
      </div>
    </div>
    <div id="fscw" style="display:none"></div>
  </div>
</div>
<script>
var src='',uSum='',qdata=[],curtab='paste',fbScore=0;
function switchTab(t){curtab=t;document.querySelectorAll('.tab').forEach(function(b,i){b.classList.toggle('active',(i===0&&t==='paste')||(i===1&&t==='file'))});document.getElementById('t-p').style.display=t==='paste'?'block':'none';document.getElementById('t-f').style.display=t==='file'?'block':'none';val1()}
function ucc(){var v=document.getElementById('pin').value;document.getElementById('cc').textContent=v.length;val1()}
function csum(){var v=document.getElementById('usum').value;document.getElementById('sc').textContent=v.length;document.getElementById('bfb').disabled=v.trim().length<80}
function val1(){var hp=curtab==='paste'&&document.getElementById('pin').value.trim().length>100;var hf=curtab==='file'&&src.length>100;document.getElementById('btn1').disabled=!(hp||hf)}
function dov(e){e.preventDefault();document.getElementById('dz').classList.add('drag')}
function dol(){document.getElementById('dz').classList.remove('drag')}
function dodrop(e){e.preventDefault();dol();if(e.dataTransfer.files[0])pf(e.dataTransfer.files[0])}
function hfile(e){if(e.target.files[0])pf(e.target.files[0])}
function pf(file){var r=new FileReader();r.onload=function(ev){src=ev.target.result;document.getElementById('dz-w').style.display='none';var fd=document.getElementById('fl-d');fd.style.display='block';fd.innerHTML='<div class="fbox"><span style="font-size:24px">&#128196;</span><div style="flex:1"><div style="font-weight:500;font-size:14px">'+file.name+'</div><div style="color:var(--mut);font-size:12px">'+Math.round(file.size/1024*10)/10+' KB</div></div><button style="background:none;border:none;color:var(--mut);cursor:pointer;font-size:18px;margin-left:auto;padding:4px" onclick="clf()">&#x2715;</button></div>';val1()};r.readAsText(file)}
function clf(){src='';document.getElementById('dz-w').style.display='block';document.getElementById('fl-d').style.display='none';val1()}
function goP(n){document.querySelectorAll('.panel').forEach(function(p,i){p.classList.toggle('active',i===n-1)});for(var i=1;i<=4;i++){var el=document.getElementById('si'+i);el.classList.remove('active','done');if(i<n)el.classList.add('done');else if(i===n)el.classList.add('active')}window.scrollTo({top:0,behavior:'smooth'})}
function go2(){if(curtab==='paste')src=document.getElementById('pin').value.trim();document.getElementById('pv2').textContent=src.substring(0,600)+(src.length>600?'...':'');document.getElementById('bfb').disabled=true;goP(2)}
async function getFB(){
uSum=document.getElementById('usum').value.trim();
if(uSum.length<80){document.getElementById('serr').style.display='block';return}
document.getElementById('serr').style.display='none';
goP(3);
document.getElementById('fbl').style.display='flex';
document.getElementById('fbc').style.display='none';
document.getElementById('fba').style.display='none';
var excerpt=src.substring(0,3000);
var prompt='You are an expert writing tutor.\n\nORIGINAL TEXT:\n"""\n'+excerpt+'\n"""\n\nSTUDENT SUMMARY:\n"""\n'+uSum+'\n"""\n\nRespond ONLY with JSON no markdown: {"score":integer0to100,"scoreLabel":"Excellent or Good or Fair or Needs Work","positive":"2-3 sentences on strengths","improve":"2-3 specific improvement sentences","missing":"1-2 sentences on missed key ideas or write Nothing major missed","tip":"one actionable writing tip"}';
try{
var res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,messages:[{role:'user',content:prompt}]})});
var d=await res.json();
var raw=d.content.map(function(b){return b.text||''}).join('').replace(/```json|```/g,'').trim();
var fb=JSON.parse(raw);
fbScore=fb.score;
renderFB(fb);
}catch(e){
document.getElementById('fbl').style.display='none';
document.getElementById('fbc').innerHTML='<div class="err">Something went wrong. Please try again.</div>';
document.getElementById('fbc').style.display='block';
}}
function renderFB(fb){
document.getElementById('fbl').style.display='none';
var r=46,circ=2*Math.PI*r,off=circ-(fb.score/100)*circ;
var rc=fb.score>=80?'var(--ok)':fb.score>=60?'var(--acc)':'var(--ac3)';
document.getElementById('fbc').innerHTML=
'<div class="rw"><div class="ring"><svg width="110" height="110" viewBox="0 0 110 110"><circle class="rt" cx="55" cy="55" r="'+r+'"/><circle class="rf" cx="55" cy="55" r="'+r+'" stroke-dasharray="'+circ+'" stroke-dashoffset="'+circ+'" id="rfill" style="stroke:'+rc+'"/></svg><div class="rtx"><div class="rn">'+fb.score+'</div><div class="rlb">/ 100</div></div></div><div style="margin-top:10px;font-family:Syne,sans-serif;font-weight:700;font-size:15px;">'+fb.scoreLabel+'</div></div>'+
'<div class="fbb pos"><div class="fblb">&#10003; What you did well</div><p>'+fb.positive+'</p></div>'+
'<div class="fbb imp"><div class="fblb">&#8593; How to improve</div><p>'+fb.improve+'</p></div>'+
'<div class="fbb mis"><div class="fblb">&#9711; Key ideas coverage</div><p>'+fb.missing+'</p></div>'+
'<div style="background:var(--s2);border-radius:10px;padding:14px 16px;margin-top:4px"><div style="font-size:11px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--acc);margin-bottom:6px">&#128161; Pro Tip</div><p style="font-size:14px">'+fb.tip+'</p></div>';
document.getElementById('fbc').style.display='block';
document.getElementById('fba').style.display='flex';
setTimeout(function(){var el=document.getElementById('rfill');if(el)el.style.strokeDashoffset=off},100)}
async function startQuiz(){
goP(4);
document.getElementById('ql').style.display='flex';
document.getElementById('qc').style.display='none';
document.getElementById('qa').style.display='none';
document.getElementById('fscw').style.display='none';
var excerpt=src.substring(0,3000);
var prompt='Create a 5-question reading comprehension quiz for this text:\n"""\n'+excerpt+'\n"""\nUse at least 3 multiple-choice (4 options) and 1-2 short-answer questions.\nRespond ONLY with a JSON array no markdown.\nFor MC: {"type":"mc","question":"...","options":["A) ...","B) ...","C) ...","D) ..."],"answer":"A","explanation":"..."}\nFor SA: {"type":"sa","question":"...","sampleAnswer":"...","keywords":["w1","w2","w3"]}';
try{
var res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1500,messages:[{role:'user',content:prompt}]})});
var d=await res.json();
var raw=d.content.map(function(b){return b.text||''}).join('').replace(/```json|```/g,'').trim();
qdata=JSON.parse(raw);
renderQuiz();
}catch(e){
document.getElementById('ql').style.display='none';
document.getElementById('qc').innerHTML='<div class="err">Could not generate quiz. Please try again.</div>';
document.getElementById('qc').style.display='block';
}}
function renderQuiz(){
document.getElementById('ql').style.display='none';
var L=['A','B','C','D'],html='';
qdata.forEach(function(q,qi){
if(q.type==='mc'){
html+='<div class="qq" id="q'+qi+'"><div class="qn">Question '+(qi+1)+' &middot; Multiple Choice</div><div class="qt">'+q.question+'</div><div class="opts">';
q.options.forEach(function(opt,oi){html+='<button class="opt" id="o'+qi+'_'+oi+'" onclick="selMC('+qi+','+oi+')"><span class="ol">'+L[oi]+'</span><span>'+opt.replace(/^[A-D]\)\s*/,'')+'</span></button>'});
html+='</div><div class="qr" id="r'+qi+'"></div></div>';
}else{
html+='<div class="qq" id="q'+qi+'"><div class="qn">Question '+(qi+1)+' &middot; Short Answer</div><div class="qt">'+q.question+'</div><div class="saw"><textarea id="sa'+qi+'" placeholder="Type your answer here..."></textarea></div></div>';
}});
document.getElementById('qc').innerHTML=html;
document.getElementById('qc').style.display='block';
document.getElementById('qa').style.display='flex'}
function selMC(qi,sel){
var q=qdata[qi],L=['A','B','C','D'],ci=L.indexOf(q.answer);
for(var i=0;i<4;i++){var b=document.getElementById('o'+qi+'_'+i);if(!b)continue;b.disabled=true;b.classList.remove('correct','wrong');if(i===ci)b.classList.add('correct');else if(i===sel)b.classList.add('wrong')}
var r=document.getElementById('r'+qi);r.classList.add('show');
if(sel===ci){r.classList.add('cm');r.textContent='Correct! '+q.explanation}
else{r.classList.add('wm');r.textContent='Not quite. '+q.explanation}}
async function submitQuiz(){
document.getElementById('bsub').disabled=true;
document.getElementById('bsub').textContent='Grading...';
var L=['A','B','C','D'],mcC=0,mcT=0,sa=[];
qdata.forEach(function(q,qi){
if(q.type==='mc'){
mcT++;
var ci=L.indexOf(q.answer),r=document.getElementById('r'+qi);
if(!r.classList.contains('show')){
var b=document.getElementById('o'+qi+'_'+ci);if(b)b.classList.add('correct');
for(var i=0;i<4;i++){var bt=document.getElementById('o'+qi+'_'+i);if(bt)bt.disabled=true}
r.classList.add('show','wm');r.textContent='Not answered. '+q.explanation;
}else if(r.classList.contains('cm'))mcC++;
}else{
var v=(document.getElementById('sa'+qi)||{}).value||'';
sa.push({qi:qi,q:q.question,a:v.trim(),sa:q.sampleAnswer,kw:q.keywords});
}});
var saScore=0;
if(sa.length>0){
try{
var sp='Grade these short answers 0-10 each. Return ONLY JSON array [{score:N,feedback:"..."},...] no markdown.\n'+sa.map(function(s,i){return 'Q'+(i+1)+': '+s.q+'\nSample: '+s.sa+'\nKeywords: '+s.kw.join(', ')+'\nStudent: "'+s.a+'"'}).join('\n\n');
var res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:600,messages:[{role:'user',content:sp}]})});
var d=await res.json();
var raw=d.content.map(function(b){return b.text||''}).join('').replace(/```json|```/g,'').trim();
var gs=JSON.parse(raw);
gs.forEach(function(g,i){
var qi=sa[i].qi;saScore+=g.score;
var ta=document.getElementById('sa'+qi);if(ta)ta.disabled=true;
var fe=document.createElement('div');
fe.className='qr show '+(g.score>=6?'cm':'wm');
fe.textContent='Score: '+g.score+'/10 - '+g.feedback;
